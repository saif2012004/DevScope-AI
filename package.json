{
  "name": "devscope-ai",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run dev",
    "db:push": "cd packages/db && npx prisma db push",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose stop postgres redis",
    "docker:up": "docker compose up -d",
    "docker:up:all": "docker compose --profile full up -d",
    "docker:up:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
