# Public URL of the API (used by the browser; must match CORS in the API for production)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Clerk — publishable key is safe in the client bundle; generate at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Server-side Clerk key (only when using server actions that call Clerk; keep secret in deployment)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Stripe — publishable key is safe in the client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
