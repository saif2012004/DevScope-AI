# API server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL (use your actual credentials and database name)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis
REDIS_URL=redis://localhost:6379

# Clerk (https://dashboard.clerk.com) — both keys required for @clerk/express
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Stripe (https://dashboard.stripe.com) — use test keys in development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret_here
STRIPE_PRO_PRICE_ID=price_your_stripe_pro_price_id_here

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Optional — raises GitHub API rate limits for repo validation (https://github.com/settings/tokens)
GITHUB_TOKEN=
